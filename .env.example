# Shared / runtime
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
PUBLIC_URL=http://localhost:5173

# API
PORT=4000
MONGODB_URI=mongodb://localhost:27017/cybersecurity_platform
SESSION_COOKIE_NAME=portal_session
SESSION_TTL_MINUTES=30
SESSION_REFRESH_TTL_DAYS=7
COOKIE_SECURE=false
TRUST_PROXY=false
LOG_LEVEL=info
IP_HASH_SECRET=replace-with-at-least-32-random-characters

# Transactional email provider abstraction: console | smtp
EMAIL_PROVIDER=console
EMAIL_FROM=security@example.com
ADMIN_NOTIFICATION_EMAIL=security@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Web (must contain public values only)
VITE_API_URL=/api

# Development seed only — replace before running, never use in production
SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_PASSWORD=ChangeMe-OnlyForLocalSeed-2026!
SEED_CLIENT_EMAIL=client@example.test
SEED_CLIENT_PASSWORD=ChangeMe-OnlyForLocalSeed-2026!
